            {
              "success": "true"
            },
            {
              "message": "Order {{ trigger[\"body\"][\"orderId\"] }} placed successfully for {{ trigger[\"body\"][\"customer\"] }}!"
            },
            {
              "orderId": "{{ trigger[\"body\"][\"orderId\"] }}"
            }
          ]
        }
      },
      "key": "trigger"
    }
  ],
  "variables": {
    "U24iD1Je5AKsLN3y": {
      "id": "U24iD1Je5AKsLN3y",
      "rank": "V",
      "type": "string",
      "format": "taskade-project-id"
